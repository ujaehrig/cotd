# Catcher of the Day - Configuration
# Copy this file to .env and configure your settings

# Database path (optional, defaults to user.db in script directory)
DB_PATH=user.db

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Holiday API settings
HOLIDAY_API_URL=https://date.nager.at/Api/v3/IsTodayPublicHoliday/DE?countyCode=DE-BW
HOLIDAY_API_TIMEOUT=5
HOLIDAY_REGION=BW

# Slack API timeout in seconds
SLACK_API_TIMEOUT=10

# Database cleanup settings
CLEANUP_RETENTION_DAYS=365
VACATION_RETENTION_DAYS=90

# iCal sync settings
ICAL_SYNC_TIMEOUT=10
FUZZY_MATCH_THRESHOLD=80
ICAL_CACHE_RETENTION_HOURS=24

# Takeover web app base URL (e.g. https://cotd.example.com)
TAKEOVER_BASE_URL=